# =========================================================================
# sandbox_mteb/env.example.jupyter
# Plantilla .env para despliegue alternativo en JupyterLab + OpenWebUI.
# Ver CLAUDE.md -> "Despliegue alternativo" y scripts/jupyter/README.md.
#
# Uso: cp sandbox_mteb/env.example.jupyter sandbox_mteb/.env
#      y rellenar NVIDIA_API_KEY con la api_key de OpenWebUI.
# =========================================================================
# Convenciones:
#   [INFRA]   - especifico del despliegue Jupyter
#   [DEFAULT] - valor recomendado (cambiar solo con razon)
#   [SECRET]  - reemplazar; nunca commitear .env

# =========================================================================
# EMBEDDING (OpenWebUI - demo-bge-m3, 1024 dims, simetrico)
# =========================================================================
EMBEDDING_MODEL_NAME=demo-bge-m3                              # [INFRA]
EMBEDDING_BASE_URL=https://open-webui.ia.labia.tics/api       # [INFRA]
EMBEDDING_MODEL_TYPE=symmetric                                # [DEFAULT] BGE-M3 es simetrico
EMBEDDING_BATCH_SIZE=5                                        # [DEFAULT]

# =========================================================================
# LLM (OpenWebUI - coding-qwen3-coder-next, 32K ctx, sin thinking-mode)
# =========================================================================
LLM_BASE_URL=https://open-webui.ia.labia.tics/api             # [INFRA]
LLM_MODEL_NAME=coding-qwen3-coder-next                        # [INFRA]

# Bearer token de OpenWebUI. langchain-nvidia la lee de NVIDIA_API_KEY
# automaticamente; el motor no necesita pasarla explicitamente.
NVIDIA_API_KEY=PEGA_AQUI_TU_API_KEY                           # [SECRET]

# OpenWebUI es servicio compartido -> concurrencia suave. Ajusta tras medir.
NIM_MAX_CONCURRENT_REQUESTS=8                                 # [DEFAULT]
NIM_REQUEST_TIMEOUT=120                                       # [DEFAULT]
NIM_MAX_RETRIES=3                                             # [DEFAULT]

# OpenWebUI no expone /v1/models en formato NIM (devuelve HTML) y la
# autodeteccion de context window (deuda #5) caeria al fallback silencioso
# de 4000 chars. Lo fijamos explicito. 80000 chars ~ 20K tokens; el modelo
# admite 32K tokens (~128K chars) asi que sobra margen.
GENERATION_MAX_CONTEXT_CHARS=80000                            # [INFRA]

# =========================================================================
# RETRIEVAL
# =========================================================================
RETRIEVAL_STRATEGY=LIGHT_RAG                                  # [DEFAULT]
RETRIEVAL_K=20                                                # [DEFAULT]
HNSW_NUM_THREADS=1                                            # [DEFAULT]

# =========================================================================
# RERANKER
# =========================================================================
# Sin endpoint NIM de rerank disponible en el pod Jupyter. LIGHT_RAG ya lo
# tiene gated off para indexacion; lo apagamos tambien para que MTEBConfig
# no exija la URL.
RERANKER_ENABLED=false                                        # [INFRA]

# =========================================================================
# DATASET / EVAL (no aplica en modo ingesta, pero MTEBConfig.validate los exige)
# =========================================================================
MTEB_DATASET_NAME=hotpotqa                                    # [DEFAULT]
EVAL_MAX_QUERIES=0                                            # [DEFAULT]
EVAL_MAX_CORPUS=0                                             # [DEFAULT]
GENERATION_ENABLED=true                                       # [DEFAULT]
JUDGE_FALLBACK_THRESHOLD=0.02                                 # [DEFAULT]
CORPUS_SHUFFLE_SEED=42                                        # [DEFAULT]
DEV_MODE=false                                                # [DEFAULT]

# =========================================================================
# MINIO (local en Jupyter; ver scripts/jupyter/02_minio_run.sh)
# =========================================================================
MINIO_ENDPOINT=http://127.0.0.1:9000                          # [INFRA]
MINIO_ACCESS_KEY=minioadmin                                   # [DEFAULT] root credentials del binario MinIO local
MINIO_SECRET_KEY=minioadmin                                   # [DEFAULT]
MINIO_BUCKET_NAME=lakehouse                                   # [DEFAULT] coincide con prod para que la ruta sea identica
S3_DATASETS_PREFIX=datasets/evaluation                        # [DEFAULT] modo eval (no se usa en Jupyter, pero validate lo exige)
S3_COLLECTIONS_PREFIX=admin/collections                       # [DEFAULT] coincide con ADMIN_ROOT_PREFIX/collections de LI_AD

# =========================================================================
# KG (LIGHT_RAG)
# =========================================================================
LIGHTRAG_MODE=hybrid                                          # [DEFAULT]
LIGHTRAG_GENERATION_TOP_N=10                                  # [DEFAULT]
KG_MAX_HOPS=1                                                 # [DEFAULT]
KG_MAX_TEXT_CHARS=5000                                        # [DEFAULT] guard del contrato; >= max_chunk_chars del manifest
KG_MAX_NEIGHBORS_PER_ENTITY=5                                 # [DEFAULT]
KG_MAX_ENTITIES=0                                             # [DEFAULT]
KG_KEYWORD_MAX_TOKENS=1024                                    # [DEFAULT]

# coding-qwen3-coder-next NO es thinking-mode -> defaults relajados.
# Si ves warnings de "empty content after stripping reasoning tags" en logs,
# sube a 8192 (como nemotron-3-nano).
KG_EXTRACTION_MAX_TOKENS=4096                                 # [DEFAULT]
KG_BATCH_DOCS_PER_CALL=5                                      # [DEFAULT]
KG_GLEANING_ROUNDS=0                                          # [DEFAULT]

KG_CACHE_DIR=./data/kg_cache                                  # [DEFAULT] persiste en NFS al estar bajo el repo
KG_DESCRIPTION_SYNTHESIS=false                                # [DEFAULT]
KG_SYNTHESIS_CHAR_THRESHOLD=200                               # [DEFAULT]
KG_CHUNK_KEYWORDS_ENABLED=true                                # [DEFAULT]
KG_CHUNK_KEYWORDS_TOP_K=20                                    # [DEFAULT]

KG_SYNTHESIS_ENABLED=true                                     # [DEFAULT]
KG_SYNTHESIS_MAX_CHARS=50000                                  # [DEFAULT]
KG_SYNTHESIS_TIMEOUT_S=180                                    # [DEFAULT]

# =========================================================================
# PATHS (relativos al directorio de ejecucion; ejecuta desde la raiz del repo)
# =========================================================================
DATASETS_CACHE_DIR=./data/datasets_cache                      # [DEFAULT]
EVALUATION_RESULTS_DIR=./data/results                         # [DEFAULT]
VECTOR_DB_DIR=./data/vector_db                                # [DEFAULT]
